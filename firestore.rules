rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Data validation helpers ───────────────────────────────────────────────
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'pin', 'role']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.role is string;
    }

    function isValidInventory(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'stock', 'category']) &&
             data.id is string &&
             data.price is number &&
             data.stock is number;
    }

    function isValidTab(data) {
      return data.keys().hasAll(['id', 'staffId', 'customerName', 'items', 'total', 'status', 'createdAt', 'updatedAt']) &&
             data.id is string &&
             data.staffId is string &&
             data.items is list &&
             data.total is number &&
             data.createdAt is number;
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['id', 'number', 'type', 'price', 'status']) &&
             data.price is number;
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['id', 'userName', 'userId', 'action', 'details', 'timestamp']);
    }

    // ── Staff ─────────────────────────────────────────────────────────────────
    match /staff/{staffId} {
      allow get, list: if true;
      allow create, update: if isValidUser(incoming()) && isValidId(staffId);
      allow delete: if true;
    }

    // ── Inventory ─────────────────────────────────────────────────────────────
    match /inventory/{itemId} {
      allow get, list: if true;
      allow create, update: if isValidInventory(incoming()) && isValidId(itemId);
      allow delete: if true;
    }

    // ── Tabs ──────────────────────────────────────────────────────────────────
    match /tabs/{tabId} {
      allow get, list: if true;
      allow create: if isValidTab(incoming()) && isValidId(tabId);
      allow update: if isValidTab(incoming());
      allow delete: if true;
    }

    // ── Rooms ─────────────────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow get, list: if true;
      allow create, update: if isValidRoom(incoming()) && isValidId(roomId);
      allow delete: if true;
    }

    // ── Audit Logs (append-only) ──────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow get, list: if true;
      allow create: if isValidAuditLog(incoming()) && isValidId(logId);
      allow update, delete: if false;
    }

    // ── Default deny ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: check if the requester is the MADIS platform admin ────────────
    function isMadisAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'jirush36@gmail.com' &&
             request.auth.token.email_verified == true;
    }

    // ── Helper: check if the requester owns this user record ─────────────────
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── Helper: validate staff document ──────────────────────────────────────
    function isValidStaff(data) {
      return data.keys().hasAll(['id', 'name', 'pin', 'role']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.pin is string && data.pin.size() >= 8 &&
             data.role in ['STAFF', 'SUPERVISOR', 'OWNER', 'ADMIN'];
    }

    // ── Helper: validate inventory document ──────────────────────────────────
    function isValidInventory(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'stock', 'category']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0;
    }

    // ── Helper: validate tab document ────────────────────────────────────────
    function isValidTab(data) {
      return data.keys().hasAll(['id', 'staffId', 'customerName', 'items', 'total', 'status', 'createdAt', 'updatedAt']) &&
             data.id is string &&
             data.staffId is string &&
             data.items is list &&
             data.total is number && data.total >= 0 &&
             data.status in ['OPEN', 'PAID', 'UNPAID'] &&
             data.createdAt is number;
    }

    // ── Per-subscriber top-level profile document ─────────────────────────────
    // Only the owner or MADIS admin can read. Only the owner can write.
    match /users/{userId} {
      allow read: if isOwner(userId) || isMadisAdmin();
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if false; // Accounts are never deleted via client

      // ── Staff subcollection ───────────────────────────────────────────────
      match /staff/{staffId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidStaff(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // ── Inventory subcollection ───────────────────────────────────────────
      match /inventory/{itemId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidInventory(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // ── Tabs subcollection ────────────────────────────────────────────────
      match /tabs/{tabId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTab(request.resource.data);
        allow update: if isOwner(userId) && isValidTab(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // ── Rooms subcollection ───────────────────────────────────────────────
      match /rooms/{roomId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // ── Audit Logs (append-only, no delete or edit) ───────────────────────
      match /auditLogs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
